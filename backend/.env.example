DATABASE_URL=postgresql://user:password@host:5432/nvas
SECRET_KEY=replace-with-a-long-random-secret
CORS_ORIGINS=http://localhost:5173,https://your-frontend.example.com
# Only networks you own or are explicitly authorized to assess.
ALLOWED_SCAN_NETWORKS=192.168.1.0/24
MAX_SCAN_HOSTS=256
# Create the first administrator through the database/deployment process; public
# registration always creates the unprivileged "user" role.
